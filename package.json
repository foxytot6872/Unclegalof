{
  "name": "to-lopburi-platform",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm run dev --workspace client & npm run dev --workspace server",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "build": "npm run build --workspace client && npm run build --workspace server",
    "prisma:generate": "npm run prisma:generate --workspace server",
    "prisma:migrate": "npm run prisma:migrate --workspace server",
    "prisma:studio": "npm run prisma:studio --workspace server"
  }
}
