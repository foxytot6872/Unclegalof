generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  STAFF
  INVENTORY
  DELIVERY
}

enum Status {
  paid
  pending
  deposit
}

enum DeliveryMethod {
  selfpickup
  delivery
}

model User {
  id                    String                 @id @default(uuid()) @db.Uuid
  fullName              String
  email                 String                 @unique
  passwordHash          String
  phone                 String?
  role                  UserRole               @default(STAFF)
  baseSalary            Int?
  isActive              Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  repairRecordsReported RepairRecord[]
  saleCommissions       SaleRecordCommission[]
  payrollRecords        PayrollRecord[]
}

model DeskItem {
  id            String         @id @default(uuid()) @db.Uuid
  name          String         @unique
  onsitePrice   Int
  deliveryPrice Int
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  saleRecords   SaleRecord[]
  repairRecords RepairRecord[]
}

model DeliveryFee {
  range       Int          @id
  cost        Int
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  saleRecords SaleRecord[]
}

model Promotion {
  id          String       @id @default(uuid()) @db.Uuid
  name        String       @unique
  amount      Int          @default(0)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  saleRecords SaleRecord[]
}

model SaleRecord {
  id                   String                 @id @default(uuid()) @db.Uuid
  createdAt            DateTime               @default(now())
  saleDate             DateTime
  orderNumber          String                 @unique
  deskType             String                 @db.Uuid
  quantity             Int                    @default(1)
  unitPrice            Int
  promoDiscount        Int                    @default(0)
  manualDiscount       Int                    @default(0)
  manualDiscountReason String?
  status               Status                 @default(pending)
  appliedPromotion     String?                @db.Uuid
  amount               Int
  deliveryType         DeliveryMethod         @default(selfpickup)
  deliveryRange        Int?
  workerFee            Int                    @default(0)
  workerFeeType        String?
  customerName         String?
  deliveryAddress      String?                @db.Text
  remarks              String?
  paymentSlipImage     String?                @db.Text
  paidAt               DateTime?
  deskItem             DeskItem               @relation(fields: [deskType], references: [id], onDelete: Restrict, onUpdate: Cascade)
  deliveryFee          DeliveryFee?           @relation(fields: [deliveryRange], references: [range])
  promotion            Promotion?             @relation(fields: [appliedPromotion], references: [id], onDelete: Restrict, onUpdate: Cascade)
  commissions          SaleRecordCommission[]

  @@index([saleDate])
  @@index([deskType])
  @@index([appliedPromotion])
  @@index([deliveryRange])
}

model RepairRecord {
  id          String       @id @default(uuid()) @db.Uuid
  deskItemId   String       @db.Uuid
  reportedBy   String       @db.Uuid
  createdAt    DateTime     @default(now())
  reportDate   DateTime
  quantity     Int          @default(1)
  size         String?
  color        String?
  description  String
  kind         String       @default("repair")
  status       String       @default("open")
  amount       Int
  /// Base64 data URLs (data:image/...), same pattern as SaleRecord.paymentSlipImage
  images       Json         @default("[]")
  deskItem     DeskItem     @relation(fields: [deskItemId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  reporter     User         @relation(fields: [reportedBy], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([deskItemId])
  @@index([reportedBy])
}

model SaleRecordCommission {
  id           String       @id @default(uuid()) @db.Uuid
  saleRecordId String       @db.Uuid
  userId       String       @db.Uuid
  amount       Int
  remarks      String?
  createdAt    DateTime     @default(now())
  saleRecord   SaleRecord   @relation(fields: [saleRecordId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  worker       User         @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([saleRecordId])
  @@index([userId])
  @@index([userId, createdAt])
}

model PayrollRecord {
  id              String       @id @default(uuid()) @db.Uuid
  userId          String       @db.Uuid
  month           Int
  year            Int
  baseSalary      Int
  commissionTotal Int          @default(0)
  bonus           Int?
  deduction       Int?
  totalPaid       Int
  paidAt          DateTime?
  remarks         String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  worker          User         @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([userId, year, month])
  @@index([userId])
  @@index([year, month])
}
